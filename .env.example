# Token do bot, criado com o @BotFather no Telegram
TELEGRAM_BOT_TOKEN=coloque_seu_token_aqui

# Chave da API do Gemini (Google AI Studio), usada para interpretar mensagens em linguagem natural
# Gere gratuitamente em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=coloque_sua_chave_aqui

# Modelo do Gemini usado para interpretação (gemini-1.5-flash tem uma camada gratuita generosa)
GEMINI_MODEL=gemini-1.5-flash

# Connection string do Supabase (Project Settings > Database > Connection string > URI)
# Use a porta 5432 (conexão direta), pois o bot mantém um processo contínuo.
# Exemplo: postgresql://postgres:SUASENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:SUASENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Pasta onde os backups diários (pg_dump) serão salvos
BACKUP_DIR=./data/backups

# IDs do Telegram (números) dos administradores, separados por vírgula
# Descubra seu ID conversando com o bot @userinfobot no Telegram
ADMIN_TELEGRAM_IDS=123456789
